# Copie este arquivo para um novo chamado ".env" e cole sua chave da Anthropic.
# (o arquivo .env NAO vai para o Git — fica so no seu computador)
ANTHROPIC_API_KEY=cole-sua-chave-aqui

# Painel de reservas (pagina web da equipe).
# Defina uma senha FORTE — sem ela, o painel nao liga (o bot roda normal mesmo assim).
# Para acessar: abra http://SEU_IP:3000 e use qualquer usuario + esta senha.
PAINEL_SENHA=troque-por-uma-senha-forte
# Porta do painel (opcional, padrao 3000).
PAINEL_PORTA=3000
